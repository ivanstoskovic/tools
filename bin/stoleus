#!/usr/bin/env bash

# ==============================================================================
# Stoleus CLI - Main Entry Point
# ==============================================================================
#
# This is the main executable for the Stoleus administration tools.
#
# When we eventually install Stoleus, the user will execute commands such as:
#
#     stoleus help
#     stoleus version
#     stoleus health
#
# This file is responsible for:
#
#   1. Determining where the Stoleus project is located.
#   2. Loading shared functions.
#   3. Reading the command entered by the user.
#   4. Routing that command to the appropriate command implementation.
#
# IMPORTANT:
# Keep this file relatively small.
# The actual implementation of individual commands belongs in:
#
#     commands/
#
# Shared reusable functions belong in:
#
#     lib/
#
# ==============================================================================


# ------------------------------------------------------------------------------
# Enable strict Bash error handling.
#
# set
#     Changes Bash shell options.
#
# -E
#     Makes ERR traps propagate into functions and subshells.
#
# -e
#     Stops the script when a command fails instead of blindly continuing.
#
# -u
#     Treats the use of an undefined variable as an error.
#
# -o pipefail
#     If any command inside a pipeline fails, the entire pipeline is considered
#     failed.
#
# Together these options make infrastructure scripts safer and help us detect
# errors early.
# ------------------------------------------------------------------------------
set -Eeuo pipefail


# ------------------------------------------------------------------------------
# Determine the absolute directory containing THIS script.
#
# BASH_SOURCE[0]
#     Contains the path of the currently executing Bash script.
#
# dirname
#     Removes the filename and returns only its directory.
#
# Example:
#
#     /home/ivan/tools/bin/stoleus
#
# becomes:
#
#     /home/ivan/tools/bin
#
# cd -- "..."
#     Changes into that directory.
#
#     The "--" tells `cd` that anything after it should be treated as an
#     argument rather than as a command option.
#
# pwd
#     Prints the absolute path of the current directory.
#
# $(...)
#     Bash command substitution.
#
# readonly
#     Makes the variable immutable after assignment.
# ------------------------------------------------------------------------------
readonly SCRIPT_DIR="$(
    cd -- "$(dirname -- "${BASH_SOURCE[0]}")"
    pwd
)"


# ------------------------------------------------------------------------------
# Determine the root directory of the entire tools project.
#
# SCRIPT_DIR points to:
#
#     /home/ivan/tools/bin
#
# ".." means parent directory.
#
# Therefore:
#
#     /home/ivan/tools/bin/..
#
# becomes:
#
#     /home/ivan/tools
# ------------------------------------------------------------------------------
readonly PROJECT_ROOT="$(
    cd -- "${SCRIPT_DIR}/.."
    pwd
)"


# ------------------------------------------------------------------------------
# Load shared Bash functions.
#
# source
#     Reads another Bash file and executes it inside the CURRENT shell.
#
# This loads:
#
#     lib/common.sh
#
# and makes functions such as:
#
#     run_command
#     print_error
#     read_version
#
# available here.
# ------------------------------------------------------------------------------
source "${PROJECT_ROOT}/lib/common.sh"


# ==============================================================================
# main
# ==============================================================================
#
# This is the main function of the Stoleus CLI.
#
# "$@"
#     Represents ALL arguments passed to the script.
#
# Example:
#
#     stoleus version
#
# gives:
#
#     $1 = version
#
# Example:
#
#     stoleus health --verbose
#
# gives:
#
#     $1 = health
#     $2 = --verbose
#
# ==============================================================================

main() {

    # --------------------------------------------------------------------------
    # Read the first command-line argument.
    #
    # ${1:-help}
    #
    # means:
    #
    #     use $1 if it exists
    #
    # otherwise:
    #
    #     use "help"
    #
    # Therefore simply running:
    #
    #     stoleus
    #
    # behaves like:
    #
    #     stoleus help
    # --------------------------------------------------------------------------
    local command="${1:-help}"


    # --------------------------------------------------------------------------
    # `case` is similar to a C# switch statement.
    #
    # We compare the value stored in `command` against several possible
    # command names.
    # --------------------------------------------------------------------------
    case "$command" in


        # ======================================================================
        # HELP
        # ======================================================================
        #
        # These are equivalent:
        #
        #     stoleus help
        #     stoleus -h
        #     stoleus --help
        #
        # "|" means OR inside a case pattern.
        # ======================================================================
        help|-h|--help)

            # ------------------------------------------------------------------
            # Remove the first positional argument because we have already
            # processed it.
            #
            # `|| true` prevents strict mode from treating an empty shift as
            # fatal.
            # ------------------------------------------------------------------
            shift || true


            # ------------------------------------------------------------------
            # Dispatch to:
            #
            #     commands/help.sh
            #
            # Any remaining arguments are forwarded using "$@".
            # ------------------------------------------------------------------
            run_command "help" "$@"

            ;;
            

        # ======================================================================
        # VERSION
        # ======================================================================
        #
        # These are equivalent:
        #
        #     stoleus version
        #     stoleus -v
        #     stoleus --version
        # ======================================================================
        version|-v|--version)

            # Remove the already processed command argument.
            shift || true


            # Dispatch to:
            #
            #     commands/version.sh
            # ------------------------------------------------------------------
            run_command "version" "$@"

            ;;


        # ======================================================================
        # HEALTH
        # ======================================================================
        #
        # Supports:
        #
        #     stoleus health
        #
        # Later it can also support arguments such as:
        #
        #     stoleus health --verbose
        #
        #     stoleus health --repair
        #
        # The actual implementation belongs in:
        #
        #     commands/health.sh
        #
        # which then uses:
        #
        #     lib/health.sh
        #
        # Mental model:
        #
        #     bin/stoleus
        #          |
        #          v
        #     commands/health.sh
        #          |
        #          v
        #     lib/health.sh
        #
        # ======================================================================
        health)

            # ------------------------------------------------------------------
            # Remove the first argument:
            #
            #     health
            #
            # This leaves any additional arguments available.
            #
            # Example:
            #
            # Before:
            #
            #     $1 = health
            #     $2 = --verbose
            #
            # After shift:
            #
            #     $1 = --verbose
            # ------------------------------------------------------------------
            shift || true


            # ------------------------------------------------------------------
            # Dispatch to:
            #
            #     commands/health.sh
            #
            # "$@"
            #     forwards all remaining arguments.
            # ------------------------------------------------------------------
            run_command "health" "$@"

            ;;


        # ======================================================================
        # UNKNOWN COMMAND
        # ======================================================================
        #
        # `*` is the fallback pattern.
        #
        # It matches anything not handled above.
        #
        # Example:
        #
        #     stoleus something
        #
        # arrives here.
        # ======================================================================
        *)

            # ------------------------------------------------------------------
            # Print the error to stderr using our shared helper.
            # ------------------------------------------------------------------
            print_error "Unknown command: $command"


            # Print a blank line for readability.
            echo


            # ------------------------------------------------------------------
            # Show help so the user can immediately see valid commands.
            # ------------------------------------------------------------------
            run_command "help"


            # ------------------------------------------------------------------
            # Return exit code 2.
            #
            # Convention:
            #
            #     0 = success
            #     non-zero = failure
            #
            # We use 2 for invalid command/usage.
            #
            # Because we are inside a function, we use `return`.
            # ------------------------------------------------------------------
            return 2

            ;;
    esac
}


# ==============================================================================
# Start the program.
# ==============================================================================
#
# Defining main() does not execute it automatically.
#
# We explicitly call:
#
#     main "$@"
#
# "$@"
#     forwards all arguments originally given to the program.
#
# Example:
#
#     ./bin/stoleus health
#
# effectively becomes:
#
#     main "health"
#
# This gives our Bash program a clear entry point similar to Main() in C#.
# ==============================================================================

main "$@"